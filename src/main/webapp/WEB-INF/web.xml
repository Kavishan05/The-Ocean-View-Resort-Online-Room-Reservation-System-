<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.oceanview.resort.controller.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/dashboard</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/logout</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/reservations/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/reservations</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/staff/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/staff</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HelpServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.HelpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HelpServlet</servlet-name>
        <url-pattern>/help</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddReservationServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.reservation.AddReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddReservationServlet</servlet-name>
        <url-pattern>/reservations/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewReservationsServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.reservation.ViewReservationsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewReservationsServlet</servlet-name>
        <url-pattern>/reservations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SearchReservationServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.reservation.SearchReservationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchReservationServlet</servlet-name>
        <url-pattern>/reservations/search</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BillServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.reservation.BillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BillServlet</servlet-name>
        <url-pattern>/reservations/bill</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.staff.AddStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStaffServlet</servlet-name>
        <url-pattern>/staff/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ManageStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.staff.ManageStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ManageStaffServlet</servlet-name>
        <url-pattern>/staff/manage</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.staff.EditStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditStaffServlet</servlet-name>
        <url-pattern>/staff/edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteStaffServlet</servlet-name>
        <servlet-class>com.oceanview.resort.controller.staff.DeleteStaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteStaffServlet</servlet-name>
        <url-pattern>/staff/delete</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>